<%- include('partials/header') %>

<div class="container mt-5">

    <h1 class="mb-4">All Job Notifications</h1>

    <% if (jobs.length === 0) { %>

        <div class="alert alert-info">
            No jobs available.
        </div>

    <% } %>

    <% jobs.forEach(job => { %>

        <div class="card mb-4 shadow-sm">

            <div class="card-body">

                <h3><%= job.title %></h3>

                <p>
                    <strong>Company:</strong>
                    <%= job.company %>
                </p>

                <p>
                    <strong>Location:</strong>
                    <%= job.location %>
                </p>

                <p>
                    <strong>Salary:</strong>
                    <%= job.salary %>
                </p>

                <p>
                    <%= job.description %>
                </p>

                <a
                    href="<%= job.apply_link %>"
                    target="_blank"
                    class="btn btn-success">

                    Apply Now

                </a>

            </div>

        </div>

    <% }) %>

</div>

<%- include('partials/footer') %>