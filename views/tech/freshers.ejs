<%- include('../partials/header') %>

<h1>Tech Freshers Jobs</h1>

<% if (jobs.length === 0) { %>

    <div class="alert alert-warning">
        No jobs available.
    </div>

<% } %>

<% jobs.forEach(job => { %>

<div class="card mb-3">

    <div class="card-body">

        <h3><%= job.title %></h3>

        <h5><%= job.company %></h5>

        <p><b>Location:</b> <%= job.location %></p>

        <p><b>Salary:</b> <%= job.salary %></p>

        <p><%= job.description %></p>

        <a
            href="<%= job.apply_link %>"
            target="_blank"
            class="btn btn-success">

            Apply Now

        </a>

    </div>

</div>

<% }) %>

<%- include('../partials/footer') %>